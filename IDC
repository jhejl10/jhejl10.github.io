        .option-item:hover { border-color: #9ca3af; background-color: #f9fafb; }
        .option-item.selected { border-color: #4f46e5; background-color: #eef2ff; box-shadow: 0 0 0 2px #a5b4fc; }
         .option-item.disabled { opacity: 0.5; cursor: not-allowed; background-color: #f3f4f6; pointer-events: none; }
        .option-item img { display: block; margin: 0 auto 0.5rem auto; height: 40px; width: auto; max-width: 100%; object-fit: contain; border-radius: 0.25rem; }
        .option-item span { display: block; font-size: 0.75rem; color: #374151; line-height: 1.2; min-height: 2.4em; }
         .option-item.selected span { font-weight: 600; color: #1f2937; }

        /* Input Field Styles */
        .input-field {
             margin-top: 0.25rem; display: block; width: 100%; border: 1px solid #d1d5db;
             border-radius: 0.375rem; box-shadow: inset 0 1px 2px rgba(0,0,0,0.05);
             padding: 0.5rem 0.75rem; font-size: 0.875rem;
        }
         .input-field:focus { outline: 2px solid transparent; outline-offset: 2px; border-color: #4f46e5; box-shadow: 0 0 0 2px #a5b4fc; }

        /* --- Prev/Next Navigation Styles --- */
        .tab-navigation { display: flex; justify-content: space-between; margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid #e5e7eb; }
        .nav-button {
