        function handleInputChange(event) {
            const inputElement = event.target;
            const optionGroup = inputElement.name;
            if (optionGroup && selectedOptions.hasOwnProperty(optionGroup)) {
                 selectedOptions[optionGroup] = inputElement.value;
                 updateDisplayAndPreview();
            }
        }

        /** Filters Door Type, Style, and Slab Material based on Product Line and Series */
        function filterOptionsBasedOnProductLineAndSeries() {
             const productLine = selectedOptions['product-line'];
             const series = selectedOptions['door-series'];
             let firstVisibleType = null;
             let isCurrentTypeVisible = false;
             let firstVisibleStyle = null;
             let isCurrentStyleVisible = false;
             let firstVisibleMaterial = null;
             let isCurrentMaterialVisible = false;

             // --- Filter Door Type ---
             doorTypeContainer.querySelectorAll('.option-item').forEach(item => {
                 const applicableLines = item.dataset.productLine ? item.dataset.productLine.split(' ') : [];
                 const isVisible = applicableLines.includes(productLine);
                 item.classList.toggle('hidden', !isVisible);
                 if (isVisible && !firstVisibleType) firstVisibleType = item.dataset.value;
                 if (isVisible && item.dataset.value === selectedOptions['door-type']) isCurrentTypeVisible = true;
             });
             if (!isCurrentTypeVisible && firstVisibleType) {
                 selectedOptions['door-type'] = firstVisibleType;
                 initializeSelections(['door-type']);
             }

             // --- Filter Door Style ---
             const showStyle = productLine !== 'frame_only';
             if (showStyle) {
                 doorStyleContainer.querySelectorAll('.option-item').forEach(item => {
                     const applicableSeries = item.dataset.series ? item.dataset.series.split(' ') : [];
                     const isVisible = applicableSeries.includes(series);
                     item.classList.toggle('hidden', !isVisible);
                     if (isVisible && !firstVisibleStyle) firstVisibleStyle = item.dataset.value;
                     if (isVisible && item.dataset.value === selectedOptions['door-style']) isCurrentStyleVisible = true;
                 });
                 if (!isCurrentStyleVisible && firstVisibleStyle) {
                     selectedOptions['door-style'] = firstVisibleStyle;
                     initializeSelections(['door-style']);
                 }
             }

             // --- Filter Slab Material ---
             const showSlabMaterial = showStyle && (series === 'flush_series' || series === 'wood_pine' || series === 'wood_oak');
             slabMaterialContainer.classList.toggle('hidden', !showSlabMaterial);
             summaryItems['slab_material'].classList.toggle('hidden', !showSlabMaterial);
             if (showSlabMaterial) {
                 slabMaterialContainer.querySelectorAll('.option-item').forEach(item => {
                     const applicableSeries = item.dataset.series ? item.dataset.series.split(' ') : [];
                     const isVisible = applicableSeries.includes(series);
                     item.classList.toggle('hidden', !isVisible);
                     if (isVisible && !firstVisibleMaterial) firstVisibleMaterial = item.dataset.value;
                     if (isVisible && item.dataset.value === selectedOptions['slab-material']) isCurrentMaterialVisible = true;
                 });
                 if (!isCurrentMaterialVisible && firstVisibleMaterial) {
                     selectedOptions['slab-material'] = firstVisibleMaterial;
                     initializeSelections(['slab-material']);
                 }
             } else {
                 selectedOptions['slab-material'] = 'primed_mdf';
             }
        }


        /** Shows/hides conditional options and updates their state/appearance. */
        function updateConditionalOptions() {
            const productLine = selectedOptions['product-line'];
            const type = selectedOptions['door-type'];
            const series = selectedOptions['door-series'];
            const boreOption = selectedOptions['bore-options'];
            const cutDown = selectedOptions['cut-down-slab'];
            const addLabel = selectedOptions['door-label'];

            const isFrameOnly = productLine === 'frame_only';
            const isDoorProduct = !isFrameOnly;

            // --- Filter dependent options first ---
            filterOptionsBasedOnProductLineAndSeries();

            // --- Show/Hide Series ---
            seriesOptionContainer.classList.toggle('hidden', isFrameOnly);
            summaryItems['door_series'].classList.toggle('hidden', isFrameOnly);
            if (isFrameOnly) selectedOptions['door-series'] = 'molded';

            // --- Show/Hide Style Tab & Content ---
            styleTabButton.classList.toggle('disabled', isFrameOnly);
            summaryItems['door_style'].classList.toggle('hidden', isFrameOnly);
             if (isFrameOnly && styleTabButton.classList.contains('active')) {
                 switchTab({ currentTarget: document.querySelector('.tab-button[data-tab="product"]') });
             }
             if (isFrameOnly) selectedOptions['door-style'] = 'molded_colonist_smooth';


            // --- Core Option ---
            const showCore = isDoorProduct && (series === 'molded' || series === 'flush_series');
            coreOptionContainer.classList.toggle('hidden', !showCore);
            summaryItems['door_core'].classList.toggle('hidden', !showCore);
            if (!showCore) selectedOptions['door-core'] = 'hollow';

            // --- Handing Option ---
            const handingApplies = !isFrameOnly && (type === 'single_prehung' || type === 'double_prehung');
            handingOptionContainer.querySelectorAll('.option-item').forEach(item => {
                item.classList.toggle('disabled', !handingApplies && item.dataset.value !== 'none');
            });
            summaryItems['door_handing'].classList.toggle('hidden', !handingApplies);
            if (!handingApplies) selectedOptions['door-handing'] = 'none';
            else if (selectedOptions['door-handing'] === 'none') selectedOptions['door-handing'] = 'left';

            // --- Bore & Hinge Tab/Options ---
            const boreHingeApplies = isDoorProduct && (type === 'slab' || type === 'single_prehung' || type === 'double_prehung');
            boreHingeTabButton.classList.toggle('disabled', !boreHingeApplies);
            boreOptionsContainer.classList.toggle('hidden', !boreHingeApplies);
            hingeTypeContainer.classList.toggle('hidden', !boreHingeApplies);
            hingeFinishContainer.classList.toggle('hidden', !boreHingeApplies);
            summaryItems['bore_options'].classList.toggle('hidden', !boreHingeApplies);
            summaryItems['hinge_type'].classList.toggle('hidden', !boreHingeApplies);
            summaryItems['hinge_finish'].classList.toggle('hidden', !boreHingeApplies);
            if (!boreHingeApplies) {
                 selectedOptions['bore-options'] = 'none'; selectedOptions['hinge-type'] = 'plain';
                 selectedOptions['hinge-finish'] = 'satin_nickel';
            }

            // --- Bore Backset Option ---
            const showBackset = boreHingeApplies && (boreOption === 'single' || boreOption === 'double');
            boreBacksetContainer.classList.toggle('hidden', !showBackset);
            summaryItems['bore_backset'].classList.toggle('hidden', !showBackset);
            if (!showBackset) selectedOptions['bore-backset'] = '2.375';

            // --- Frame Tab/Options ---
            const frameApplies = type === 'single_prehung' || type === 'double_prehung' || type === 'single_frame' || type === 'double_frame' || type === 'cased_opening';
            frameTabButton.classList.toggle('disabled', !frameApplies);
            summaryItems['jamb_size'].classList.toggle('hidden', !frameApplies);
            summaryItems['jamb_type'].classList.toggle('hidden', !frameApplies);
            summaryItems['jamb_material'].classList.toggle('hidden', !frameApplies);
            summaryItems['door_stop'].classList.toggle('hidden', !frameApplies || type === 'cased_opening');
            summaryItems['door_casing'].classList.toggle('hidden', !frameApplies);
             if (!frameApplies) {
                 selectedOptions['jamb-size'] = '4.5625'; selectedOptions['jamb-type'] = 'flat';
                 selectedOptions['jamb-material'] = 'fj_pine'; selectedOptions['door-stop'] = 'standard';
                 selectedOptions['door-casing'] = 'none';
             }

            // --- Custom Sizing Tab/Options ---
            const customSizingApplies = isDoorProduct;
            customSizeTabButton.classList.toggle('disabled', !customSizingApplies);
            summaryItems['cut_down_slab'].classList.toggle('hidden', !customSizingApplies);
            summaryItems['cut_down_height'].classList.toggle('hidden', !customSizingApplies);
            summaryItems['bore_vertical_pos'].classList.toggle('hidden', !customSizingApplies);
            if (!customSizingApplies) {
                 selectedOptions['cut-down-slab'] = 'no';
                 selectedOptions['cut-down-height'] = '';
                 selectedOptions['bore-vertical-pos'] = 'top_44';
            } else {
                 const showCutDownDetails = cutDown === 'yes';
                 cutDownDetailsContainer.classList.toggle('hidden', !showCutDownDetails);
                 summaryItems['cut_down_slab'].classList.toggle('hidden', !showCutDownDetails);
                 summaryItems['cut_down_height'].classList.toggle('hidden', !showCutDownDetails);
                 if (!showCutDownDetails) selectedOptions['cut-down-height'] = '';

                 const showBorePos = showCutDownDetails && boreHingeApplies && (boreOption === 'single' || boreOption === 'double');
                 boreVerticalPosContainer.classList.toggle('hidden', !showBorePos);
                 summaryItems['bore_vertical_pos'].classList.toggle('hidden', !showBorePos);
                 if (!showBorePos) selectedOptions['bore-vertical-pos'] = 'top_44';
            }


            // --- Shipping Label Options ---
            const showLabelText = addLabel === 'yes';
            labelTextContainer.classList.toggle('hidden', !showLabelText);
            summaryItems['door_label'].classList.toggle('hidden', !showLabelText);
            summaryItems['label_text'].classList.toggle('hidden', !showLabelText);
             if (!showLabelText) selectedOptions['label-text'] = '';

            // --- Tab Switching Logic ---
             const activeTabButton = document.querySelector('.tab-button.active');
             if (activeTabButton && activeTabButton.classList.contains('disabled')) {
                 const firstEnabledTab = document.querySelector('.tab-button:not(.disabled)');
                 if (firstEnabledTab) switchTab({ currentTarget: firstEnabledTab });
             }

            initializeSelections(Object.keys(selectedOptions));
            updateNavButtonStates();
        }


        /** Calculates the total price based on current selections stored in selectedOptions. */
        function calculatePrice() {
             let total = 0;
             const productLine = selectedOptions['product-line'];
             const type = selectedOptions['door-type'];
             const series = selectedOptions['door-series'];
             const core = selectedOptions['door-core'];
             const style = selectedOptions['door-style'];
             const slabMat = selectedOptions['slab-material'];
             const width = selectedOptions['door-width'];
             const height = selectedOptions['door-height'];
             const thickness = selectedOptions['door-thickness'];
             const handing = selectedOptions['door-handing'];
             const bore = selectedOptions['bore-options'];
             const hingeType = selectedOptions['hinge-type'];
             const hingeFinish = selectedOptions['hinge-finish'];
             const jambSize = selectedOptions['jamb-size'];
             const jambType = selectedOptions['jamb-type'];
             const jambMat = selectedOptions['jamb-material'];
             const doorStop = selectedOptions['door-stop'];
             const casing = selectedOptions['door-casing'];
             const cutDown = selectedOptions['cut-down-slab'];
             const addLabel = selectedOptions['door-label'];

             total += pricing.productLines[productLine] || 0;

             if (productLine === 'frame_only') {
                 total += pricing.types[type] || 0;
                 total += (pricing.jambSizes[jambSize] || 0);
                 total += (pricing.jambTypes[jambType] || 0);
                 total += (pricing.jambMaterials[jambMat] || 0);
                 if (type !== 'cased_opening') { total += (pricing.doorStops[doorStop] || 0); }
                 total += (pricing.doorCasings[casing] || 0);
                 total += (addLabel === 'yes' ? pricing.doorLabel.yes : 0);
                 return total;
             }

             const showCore = series === 'molded' || series === 'flush_series';
             const coreCost = showCore ? (pricing.cores[core] || 0) : 0;

             const boreHingeApplies = type === 'slab' || type === 'single_prehung' || type === 'double_prehung';
             const boreCost = boreHingeApplies ? (pricing.boreOptions[bore] || 0) : 0;
             const hingeCost = boreHingeApplies ? (pricing.hingeTypes[hingeType] || 0) + (pricing.hingeFinishes[hingeFinish] || 0) : 0;
             const numHinges = (parseInt(height) || 80) >= 96 ? 4 : 3;
             const totalHingeCost = hingeCost * numHinges;

             const frameApplies = type === 'single_prehung' || type === 'double_prehung';
             const frameCost = frameApplies ? (pricing.jambSizes[jambSize] || 0) + (pricing.jambTypes[jambType] || 0) + (pricing.jambMaterials[jambMat] || 0) + (pricing.doorStops[doorStop] || 0) + (pricing.doorCasings[casing] || 0) : 0;

             const handingApplies = type === 'single_prehung' || type === 'double_prehung';
             const handingCost = handingApplies ? (pricing.handing[handing] || 0) : 0;

             const cutDownCost = (cutDown === 'yes' ? pricing.cutDown.yes : 0);
             const labelCost = (addLabel === 'yes' ? pricing.doorLabel.yes : 0);

             const currentStyle = selectedOptions['door-style'];
             const currentSlabMat = selectedOptions['slab-material'];

             let singleUnitCost = pricing.base + (pricing.series[series] || 0) + coreCost + (pricing.styles[currentStyle] || 0) + (pricing.slabMaterials[currentSlabMat] || 0) + (pricing.widths[width] || 0) + (pricing.heights[height] || 0) + (pricing.thicknesses[thickness] || 0) + boreCost + totalHingeCost + cutDownCost + labelCost;

             if (type === 'slab') { total += singleUnitCost; }
             else if (type === 'single_prehung') { total += singleUnitCost + (pricing.types[type] || 0) + frameCost + handingCost; }
             else if (type === 'double_prehung') { total += (singleUnitCost * 2) + (pricing.types[type] || 0) + frameCost + handingCost; }
             else if (type === 'bypass' || type === 'bifold') {
                  const numDoors = (parseInt(width) || 30) >= 48 ? 2 : 2;
                  let bypassBifoldUnitCost = pricing.base + (pricing.series[series] || 0) + coreCost + (pricing.styles[currentStyle] || 0) + (pricing.slabMaterials[currentSlabMat] || 0) + (pricing.widths[width] || 0) + (pricing.heights[height] || 0) + (pricing.thicknesses[thickness] || 0) + cutDownCost + labelCost;
                  total += (bypassBifoldUnitCost * numDoors) + (pricing.types[type] || 0);
             }

             return total;
        }

        /** Updates the 2D door preview. */
        function updatePreview() {
             const productLine = selectedOptions['product-line'];
             doorPreview.innerHTML = '';
             doorPreview.className = 'door-preview';
             doorPreview.style.backgroundColor = '#e5e7eb';

             if (productLine === 'frame_only') {
                 doorPreview.style.borderWidth = '8px';
                 doorPreview.style.borderColor = '#a1a1aa';
                 doorPreview.style.backgroundColor = '#f9fafb';
             } else {
                 doorPreview.style.borderWidth = '2px';
                 doorPreview.style.borderColor = '#4b5563';
                 const selectedStyle = selectedOptions['door-style'];
                 doorPreview.classList.add(`door-style-${selectedStyle}`);
                  if (['paneled_2', 'molded_cambridge', 'roman', 'santa_fe', 'rockport', 'shaker_2'].includes(selectedStyle)) { doorPreview.innerHTML = '<div class="door-panel"></div><div class="door-panel"></div>'; }
                  else if (['paneled_6', 'molded_colonist_smooth', 'molded_colonist_textured', 'madison'].includes(selectedStyle)) { doorPreview.innerHTML = `<div class="door-panel"></div><div class="door-panel"><div class="door-panel-inner"></div><div class="door-panel-inner"></div></div><div class="door-panel"></div>`; }
                  else if (['craftsman_iii', 'birkdale', 'conmore', 'shaker_3', 'shaker_3_craftsman'].includes(selectedStyle)) { doorPreview.innerHTML = `<div class="door-panel" style="height:20%"></div><div class="door-panel"></div><div class="door-panel"></div>`; }
                  else if (['shaker_5'].includes(selectedStyle)) { doorPreview.innerHTML = Array(5).fill('<div class="door-panel"></div>').join(''); }
                  else if (selectedStyle === 'french') { doorPreview.innerHTML = '<div class="door-panel"></div>'; const gp = doorPreview.querySelector('.door-panel'); if(gp) { gp.style.backgroundColor = '#cce7f5'; gp.style.borderColor = '#99cdee'; }}
             }
        }

        /** Finds the text associated with a selected value for a given option group. */
        function getSelectedText(optionGroup) {
            const container = document.querySelector(`.option-container[data-option-group="${optionGroup}"]`);
            if (!container || container.classList.contains('hidden')) return '';
            const selectedItem = container.querySelector(`.option-item.selected`);
            if (!selectedItem && (optionGroup === 'cut-down-height' || optionGroup === 'label-text')) {
                return selectedOptions[optionGroup];
            }
            if (selectedItem && selectedItem.classList.contains('hidden')) {
                 const firstVisibleItem = container.querySelector('.option-item:not(.hidden)');
                 return firstVisibleItem?.dataset.text || firstVisibleItem?.querySelector('span')?.textContent || '';
            }
            return selectedItem?.dataset.text || selectedItem?.querySelector('span')?.textContent || selectedOptions[optionGroup];
        }


        /** Updates the summary section, total price display, preview, and conditional options. */
        function updateDisplayAndPreview() {
            updateConditionalOptions(); // Update visibility/state first

            // Update Summary Text dynamically
            for (const key in summarySpans) {
                 const itemElement = summaryItems[key];
                 if (itemElement && summarySpans[key]) {
                     const text = getSelectedText(key.replace(/_/g, '-'));
                     summarySpans[key].textContent = text;
                     // Additionally hide/show the entire list item based on visibility logic handled in updateConditionalOptions
                     // (No need to repeat hiding logic here if summaryItems visibility is handled correctly there)
                     if (key === 'cut_down_height' && text) summarySpans[key].textContent = `${text}"`;
                     if (key === 'label_text' && !text) summarySpans[key].textContent = '(None)';

                 }
            }

            const price = calculatePrice();
            totalPriceDisplay.textContent = `$${price.toFixed(2)}`;

            priceUpdateDiv.classList.remove('bg-indigo-50');
            priceUpdateDiv.classList.add('bg-indigo-100');
            setTimeout(() => {
                priceUpdateDiv.classList.remove('bg-indigo-100');
                priceUpdateDiv.classList.add('bg-indigo-50');
            }, 150);

            updatePreview();
        }

        /** Sets the initial visual state based on the default selectedOptions. */
        function initializeSelections(groupsToUpdate = Object.keys(selectedOptions)) {
             groupsToUpdate.forEach(group => {
                 const container = document.querySelector(`.option-container[data-option-group="${group}"]`);
                 if (container) {
                     const items = container.querySelectorAll('.option-item');
                     items.forEach(item => {
                         const shouldBeSelected = item.dataset.value === selectedOptions[group];
                         item.classList.toggle('selected', shouldBeSelected && !item.classList.contains('hidden'));
                     });
                 }
                 const inputElement = document.querySelector(`[name="${group}"]`);
                  if (inputElement && (inputElement.type === 'text' || inputElement.type === 'number')) {
                      inputElement.value = selectedOptions[group];
                  }
             });
        }

        // --- Event Listeners ---
        tabButtons.forEach(button => button.addEventListener('click', switchTab));
        optionsArea.addEventListener('click', handleOptionClick);
        cutDownHeightInput.addEventListener('input', handleInputChange);
        labelTextInput.addEventListener('input', handleInputChange);
        optionsArea.addEventListener('click', (event) => {
            if (event.target.matches('.prev-tab, .next-tab')) {
                handlePrevNextClick(event);
            }
        });


        // --- Initial Setup ---
        document.addEventListener('DOMContentLoaded', () => {
            initializeSelections();
            updateDisplayAndPreview();
        });

    </script>
