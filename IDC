        .nav-button:hover:not(:disabled) { background-color: #f3f4f6; border-color: #9ca3af; }
        .nav-button:disabled { opacity: 0.5; cursor: not-allowed; background-color: #f9fafb; }

        /* --- Door Preview Styles --- */
